#!/usr/bin/env zsh
set -euo pipefail

cfg="${SSH_CONFIG:-$HOME/.ssh/config}"

typeset -A seen_files=()
typeset -A seen_hosts=()
typeset -a queue=()

enqueue_file() {
    local f="$1"
    [[ -f "$f" ]] || return 0
    [[ -n "${seen_files[$f]:-}" ]] && return 0
    seen_files[$f]=1
    queue+=("$f")
}

enqueue_file "$cfg"

while (( ${#queue[@]} > 0 )); do
    file="$queue[1]"
    shift queue

    dir="${file:a:h}"

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        # Trim leading and trailing whitespace
        line="${line#"${line%%[^[:space:]]*}"}"
        line="${line%"${line##*[^[:space:]]}"}"
        [[ -z "$line" ]] && continue

        key="${line%%[[:space:]]*}"
        rest="${line#"$key"}"
        rest="${rest#"${rest%%[^[:space:]]*}"}"
        rest="${rest%"${rest##*[^[:space:]]}"}"

        case "${(L)key}" in
            include)
                for pat in ${=rest}; do
                    pat="${pat/#\~/$HOME}"
                    [[ "$pat" != /* ]] && pat="$dir/$pat"

                    files=( ${~pat}(N) )

                    if (( ${#files[@]} > 0 )); then
                        for m in "${files[@]}"; do
                            enqueue_file "$m"
                        done
                    else
                        enqueue_file "$pat"
                    fi
                done
                ;;
            host)
                chosen=""
                for h in ${=rest}; do
                    case "$h" in
                        *[\*\?\!\[]*) continue ;;
                    esac
                    if [[ -z "$chosen" ]] || (( ${#h} < ${#chosen} )); then
                        chosen="$h"
                    fi
                done
                if [[ -n "$chosen" ]]; then
                    seen_hosts[$chosen]=1
                fi
                ;;
        esac
    done < "$file"
done

printf "%s\n" "${(k)seen_hosts[@]}" | sort -u
